<body class="bg-background text-on-background min-h-screen flex flex-col font-body-md overflow-hidden">
<!-- TopAppBar Shell (Suppressed Navigation for Transactional Page) -->
<header class="fixed top-0 left-0 w-full z-50 bg-background/80 dark:bg-background/80 backdrop-blur-xl border-b border-white/10 shadow-[0_0_15px_rgba(0,209,255,0.1)]">
<div class="flex justify-between items-center w-full px-margin-mobile md:px-margin-desktop py-4">
<div class="flex items-center gap-4 cursor-pointer active:scale-95 transition-transform">
<span class="material-symbols-outlined text-primary" data-icon="movie_edit">movie_edit</span>
<span class="font-display-lg text-headline-lg font-black text-primary uppercase tracking-widest">FILM_EDIT</span>
</div>
</div>
</header>
<!-- Main Canvas -->
<main class="relative flex-grow flex items-center justify-center pt-20 px-margin-mobile">
<!-- Cinematic Background Texture -->
<div class="absolute inset-0 z-0">
<img class="w-full h-full object-cover opacity-20 grayscale brightness-50" data-alt="A professional dark post-production suite with multiple high-definition monitors glowing with color-grading software interfaces. The room is dimly lit, reflecting a cinematic atmosphere with soft electric blue backlighting hitting the edges of high-end editing hardware and soundboards. The mood is focused and technologically advanced, suggesting a high-level creative studio environment." src="https://lh3.googleusercontent.com/aida-public/AB6AXuAz-FN8VQaMsK4rXk2AflWqGL1cLqkzg9bqFfbTWCW0Yu3E5sNwxtKgD40sTNk1lE5DvzRhjv65mRouU-FnGEMdywgs6pjlj7JTr6cZMxx6eXNE3fQ3_sJzfIhk4CI6DF7EnaKplpYF1FvVh-S1kjyKx98RV_fmXfKnx_4Yjai8i9dEWBkwF09n84DLvCUwZ2n2svs-v4vl1v5KF1UVkXNklVs9eaZYB_V6uj3gbOs3K4ize84FAEDIoaltelO0_d4aLvW_wLPNQKs"/>
<div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-background"></div>
</div>
<!-- Login Card -->
<div class="relative z-10 w-full max-w-[480px]">
<div class="bg-surface-container/60 backdrop-blur-2xl border border-white/10 p-8 md:p-12 shadow-[0_0_40px_rgba(0,209,255,0.05)] transition-all duration-500 hover:border-primary-container/30">
<div class="mb-10 text-center">
<h1 class="font-display-lg text-headline-lg font-black text-on-surface mb-2 tracking-tight uppercase">ADMIN ACCESS</h1>
<div class="h-1 w-12 bg-primary-container mx-auto"></div>
</div>
<form class="space-y-6" action="/authorised/login" method="post">
<!-- name Input -->
<div class="space-y-2">
<label class="font-label-caps text-label-caps text-on-surface-variant block uppercase">Name</label>
<div class="relative group">
<input class="w-full bg-surface-container-low border-b-2 border-outline-variant px-4 py-3 text-on-surface focus:border-primary-container focus:ring-0 transition-colors bg-opacity-50" placeholder="name" type="text" name="name"/>
</div>
</div>

<!-- Email Input -->
<div class="space-y-2">
<label class="font-label-caps text-label-caps text-on-surface-variant block uppercase">Email Address</label>
<div class="relative group">
<input class="w-full bg-surface-container-low border-b-2 border-outline-variant px-4 py-3 text-on-surface focus:border-primary-container focus:ring-0 transition-colors bg-opacity-50" placeholder="editor@filmedit.com" type="email" name="email"/>
</div>
</div>
<!-- Password Input -->
<div class="space-y-2">
<div class="flex justify-between items-center">
<label class="font-label-caps text-label-caps text-on-surface-variant block uppercase">Password</label>
<a class="font-label-caps text-label-caps text-secondary hover:text-primary transition-colors duration-300" href="#">Forgot Password?</a>
</div>
<div class="relative group">
<input class="w-full bg-surface-container-low border-b-2 border-outline-variant px-4 py-3 text-on-surface focus:border-primary-container focus:ring-0 transition-colors bg-opacity-50" placeholder="••••••••" type="password" name="password"/>
</div>
</div>
<!-- CTA -->
<div class="pt-4">
<button class="w-full py-4 bg-primary-container text-on-primary font-display-lg text-body-lg font-bold uppercase tracking-widest hover:scale-[1.02] active:scale-95 transition-all duration-300 hover:shadow-[0_0_20px_rgba(0,209,255,0.4)]" type="submit">
                            SIGN IN
                        </button>
</div>
</form>
<!-- Security Footer -->
<div class="mt-10 flex items-start gap-3 opacity-60">
<span class="material-symbols-outlined text-primary text-[20px]" data-icon="lock">lock</span>
<p class="font-label-caps text-label-caps text-on-surface-variant leading-relaxed">
                        Authorized access only. Technical sessions are monitored for security compliance.
                    </p>
</div>
</div>
</div>
</main>
<!-- Footer Shell -->
<footer class="w-full bg-surface dark:bg-surface border-t border-white/10 z-50">
<div class="flex flex-col md:flex-row justify-between items-center w-full px-margin-mobile md:px-margin-desktop py-8 gap-4">
<span class="font-label-caps text-label-caps text-on-surface-variant/60 uppercase">© 2024 FILM_EDIT POST-PRODUCTION. ALL RIGHTS RESERVED.</span>
<div class="flex gap-6">
<a class="font-label-caps text-label-caps text-on-surface-variant/60 hover:text-primary transition-opacity duration-200 uppercase" href="#">Terms of Service</a>
<a class="font-label-caps text-label-caps text-on-surface-variant/60 hover:text-primary transition-opacity duration-200 uppercase" href="#">Privacy Policy</a>
<a class="font-label-caps text-label-caps text-on-surface-variant/60 hover:text-primary transition-opacity duration-200 uppercase" href="#">Technical Support</a>
</div>
</div>
</footer>
</body></html>